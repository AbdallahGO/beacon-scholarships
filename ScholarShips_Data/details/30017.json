                                    "body":  "\u003cul\u003e\u003cli data-end=\"27\" data-start=\"2\"\u003e\u003cstrong data-end=\"25\" data-is-only-node=\"\" data-start=\"2\"\u003eTuition fee waiver.\u003c/strong\u003e\u003c/li\u003e\u003cli data-end=\"59\" data-start=\"30\"\u003e\u003cstrong data-end=\"57\" data-is-only-node=\"\" data-start=\"30\"\u003eMonthly living stipend.\u003c/strong\u003e\u003c/li\u003e\u003cli data-end=\"85\" data-start=\"62\"\u003e\u003cstrong data-end=\"83\" data-is-only-node=\"\" data-start=\"62\"\u003eResearch funding.\u003c/strong\u003e\u003c/li\u003e\u003cli data-end=\"194\" data-start=\"88\"\u003e\u003cstrong data-end=\"122\" data-is-only-node=\"\" data-start=\"88\"\u003eEnhancement of research skills\u003c/strong\u003e in modern laboratories under the supervision of USTC faculty members.\u003c/li\u003e\u003cli data-end=\"361\" data-is-last-node=\"\" data-start=\"197\"\u003eGain a \u003cstrong data-end=\"229\" data-start=\"204\"\u003ecompetitive advantage\u003c/strong\u003e when applying for \u003cstrong data-end=\"300\" data-start=\"248\"\u003eMaster\u0026rsquo;s, PhD, and postdoctoral programs at USTC\u003c/strong\u003e by building relationships with faculty members and students.\u003c/li\u003e\u003c/ul\u003e"
