                                    "body":  "\u003cdiv\u003e\u003cdiv class=\"description\"\u003e\u003cdiv\u003e\u003cdiv class=\"description\"\u003e\u003cdiv\u003e\u003cp data-end=\"439\" data-start=\"0\"\u003e\u0026Uuml;sk\u0026uuml;dar University Scholarship 2026 in Turkey offers international students opportunities to study Bachelor\u0026rsquo;s, Master\u0026rsquo;s, and PhD programs with various tuition discounts and scholarships. \u0026Uuml;sk\u0026uuml;dar University is well known for its strong programs in Medicine, Psychology, Health Sciences, and Engineering, in addition to its modern educational environment and opportunities for training and scientific research in Istanbul.\u003c/p\u003e\u003ch3 data-end=\"451\" data-section-id=\"l34gr2\" data-start=\"441\"\u003eMajors\u003c/h3\u003e\u003cul data-end=\"641\" data-is-last-node=\"\" data-is-only-node=\"\" data-start=\"452\"\u003e\u003cli data-end=\"464\" data-section-id=\"sfq1os\" data-start=\"452\"\u003eMedicine\u003c/li\u003e\u003cli data-end=\"478\" data-section-id=\"as1ohi\" data-start=\"465\"\u003eDentistry\u003c/li\u003e\u003cli data-end=\"491\" data-section-id=\"q8vzlh\" data-start=\"479\"\u003ePharmacy\u003c/li\u003e\u003cli data-end=\"506\" data-section-id=\"1mvey2z\" data-start=\"492\"\u003ePsychology\u003c/li\u003e\u003cli data-end=\"522\" data-section-id=\"kiewfl\" data-start=\"507\"\u003eEngineering\u003c/li\u003e\u003cli data-end=\"550\" data-section-id=\"wc8ypz\" data-start=\"523\"\u003eMedia and Communication\u003c/li\u003e\u003cli data-end=\"570\" data-section-id=\"1hqo39v\" data-start=\"551\"\u003eHealth Sciences\u003c/li\u003e\u003cli data-end=\"615\" data-section-id=\"16rhar8\" data-start=\"571\"\u003eArtificial Intelligence and Data Science\u003c/li\u003e\u003cli data-end=\"641\" data-is-last-node=\"\" data-section-id=\"3sduww\" data-start=\"616\"\u003eBusiness Administration\u003c/li\u003e\u003c/ul\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e"
